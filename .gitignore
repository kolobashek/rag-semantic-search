# ── Конфигурация с локальными путями ─────────────────────────────────
config.json
config.docker.json

# ── Логи ──────────────────────────────────────────────────────────────
*.log
*.log.err
logs/*
!logs/.gitkeep
!logs/archive/
logs/archive/*
!logs/archive/.gitkeep

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
.pytest_cache/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Виртуальное окружение ─────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── PyInstaller (билд EXE) ────────────────────────────────────────────
*.spec
!packaging/*.spec
dist/
build/
dist_*/
build_*/

# ── Project work dirs ─────────────────────────────────────────────────
artifacts/*
!artifacts/.gitkeep
tmp/*
!tmp/.gitkeep

# ── Qdrant база данных ────────────────────────────────────────────────
qdrant_db/
*.db
*.sqlite

# ── Временные файлы Office ────────────────────────────────────────────
~$*

# ── AI Agent worktrees ────────────────────────────────────────────────
.claude/
.codex/
.nicegui/

# ── Bundled third-party tools (large binaries) ────────────────────────
tools/*
!tools/README.md

# ── IDE / редакторы ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Конфликтующие копии (синхронизация) ───────────────────────────────
*conflicted copy*

# ── Dependency lockfiles (local) ──────────────────────────────────────
uv.lock
